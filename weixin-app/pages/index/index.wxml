<view class="container">
  <!-- 加载状态 -->
  <view class="loading-box" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text>正在调取数据...</text>
  </view>

  <!-- 页面内容区域 -->
  <scroll-view class="main-scroll" scroll-y="{{!loading}}" wx:if="{{!loading}}">
    
    <!-- 1. 上部分卡片：水位趋势 -->
    <view class="card">
      <!-- 卡片头部 -->
      <view class="card-header">
        <view class="header-title-box">
          <text class="header-title">水位趋势</text>
        </view>
        <text class="header-time">{{headerTime}}</text>
      </view>

      <!-- 图表区域 -->
      <view class="chart-area">
        <ec-canvas id="mychart-dom-bar" canvas-id="mychart-bar" ec="{{ ec }}"></ec-canvas>
      </view>

      <!-- 关键数据行 -->
      <view class="metrics-row">
        <view class="metric-item">
          <text class="metric-label">最新出库流量</text>
          <text class="metric-value">{{metrics.latestOtq}} <text class="unit">m³/s</text></text>
        </view>
        <view class="metric-divider"></view>
        <view class="metric-item">
          <text class="metric-label">最大出库流量</text>
          <text class="metric-value">{{metrics.maxOtq}} <text class="unit">m³/s</text></text>
        </view>
        <view class="metric-divider"></view>
        <view class="metric-item">
          <text class="metric-label">最小出库流量</text>
          <text class="metric-value">{{metrics.minOtq}} <text class="unit">m³/s</text></text>
        </view>
      </view>

      <!-- 分割线 -->
      <view class="section-divider"></view>

      <!-- 选中时刻数据展示 (2x2 布局) -->
      <view class="selected-data-section" wx:if="{{selectedData}}">
        <view class="section-sub-title">选中时刻数据</view>
        <view class="grid-2x2">
          <view class="grid-cell">
            <text class="grid-label">时刻</text>
            <text class="grid-value time-val">{{selectedData.formattedTime}}</text>
          </view>
          <view class="grid-cell">
            <text class="grid-label">库水位</text>
            <text class="grid-value">{{selectedData.rz}} <text class="unit">m</text></text>
          </view>
          <view class="grid-cell">
            <text class="grid-label">入库流量</text>
            <text class="grid-value">{{selectedData.inq}} <text class="unit">m³/s</text></text>
          </view>
          <view class="grid-cell">
            <text class="grid-label">出库流量</text>
            <text class="grid-value highlight">{{selectedData.otq}} <text class="unit">m³/s</text></text>
          </view>
        </view>
      </view>
    </view>

    <!-- 2. 下部分卡片：详细数据 -->
    <view class="card">
      <!-- 卡片头部 -->
      <view class="card-header">
        <view class="header-title-box">
          <text class="header-title">详细数据</text>
        </view>
        <text class="header-time">{{listTime}}</text>
      </view>

      <!-- 表格容器 -->
      <view class="table-container">
        <!-- 列表标题栏 -->
        <view class="table-header">
          <text class="col col-time">时刻</text>
          <text class="col">库水位</text>
          <text class="col">入库</text>
          <text class="col">出库</text>
        </view>

        <!-- 列表内容 -->
        <view class="table-body">
          <block wx:for="{{chartData.timeList}}" wx:key="index">
            <view class="table-row">
              <text class="col col-time">{{item}}</text>
              <text class="col">{{chartData.indexValues.rz[index] != null ? chartData.indexValues.rz[index].toFixed(2) : '--'}}</text>
              <text class="col">{{chartData.indexValues.inq[index].toFixed(2)}}</text>
              <text class="col">{{chartData.indexValues.otq[index].toFixed(2)}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- 3. 底部免责声明 -->
    <view class="disclaimer-card">
      <view class="disclaimer-header">
        <text class="tag">免责声明</text>
        <text class="title">数据仅供学习交流</text>
      </view>
      <text class="content">本程序展示数据来源于公开科研接口，非官方实时发布，不具法律效力。严禁用于防汛指挥或实务决策。若需权威数据请查阅官方通报。</text>
    </view>

    <!-- 底部安全间距 -->
    <view class="bottom-safe-area"></view>
  </scroll-view>
</view>