page { 
  height: 100%; 
  background: #f5f7fa; 
}

.container { 
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* 加载状态 */
.loading-box {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1000;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #ddd;
  border-top-color: #2196F3;
  border-radius: 50%;
  animation: rotate 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes rotate {
  to { transform: rotate(360deg); }
}

/* 主滚动区域 */
.main-scroll {
  height: 100%;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-title-box {
  background: #1976D2;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.header-title {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.header-time {
  color: #999;
  font-size: 22rpx;
}

/* 图表区域 */
.chart-area {
  width: 100%;
  height: 450rpx;
  margin-bottom: 16rpx;
}

/* 关键数据行 */
.metrics-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.metric-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.metric-label {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.metric-value {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.metric-value .unit {
  font-size: 18rpx;
  color: #999;
  font-weight: normal;
}

.metric-divider {
  width: 1rpx;
  height: 40rpx;
  background: #eee;
}

/* 分割线 */
.section-divider {
  height: 1rpx;
  background: #eee;
  margin: 16rpx 0;
}

/* 选中数据区域 */
.selected-data-section {
  margin-top: 8rpx;
}

.section-sub-title {
  font-size: 22rpx;
  color: #666;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.grid-2x2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.grid-cell {
  background: #f9f9f9;
  padding: 12rpx;
  border-radius: 8rpx;
}

.grid-label {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.grid-value {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.grid-value.highlight {
  color: #FF9800;
}

.grid-value.time-val {
  font-size: 22rpx;
  color: #1976D2;
}

/* 表格样式 */
.table-container {
  width: 100%;
}

.table-header {
  display: flex;
  background: #f0f2f5;
  padding: 12rpx 0;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.table-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  align-items: center;
}

.col {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.col-time {
  flex: 1.3;
  text-align: left;
  padding-left: 8rpx;
  font-size: 20rpx;
}

/* 免责声明样式 */
.disclaimer-card {
  background: #ffffff;
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.disclaimer-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.tag {
  font-size: 18rpx;
  background: #fff2e8;
  color: #fa541c;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  border: 1rpx solid #ffbb96;
  margin-right: 10rpx;
  font-weight: bold;
}

.title {
  font-size: 20rpx;
  color: #666;
  font-weight: bold;
}

.content {
  font-size: 18rpx;
  color: #999;
  line-height: 1.5;
  text-align: justify;
  display: block;
}

/* 底部安全区域 */
.bottom-safe-area {
  height: calc(20rpx + env(safe-area-inset-bottom));
}