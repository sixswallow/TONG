page {
  height: 100%;
  background-color: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.container {
  width: 100%;
  min-height: 100%;
}

.loading-box {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f0f2f5;
  z-index: 100;
}

.spinner {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid #e0e0e0;
  border-top-color: #1976D2;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.page-content {
  width: 100%;
  padding-bottom: env(safe-area-inset-bottom);
}

.top-bar {
  background: linear-gradient(135deg, #1565C0, #1E88E5);
  padding: 28rpx 30rpx 24rpx;
  display: flex;
  align-items: baseline;
}

.top-bar-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 16rpx;
}

.top-bar-subtitle {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-title-box {
  background: linear-gradient(135deg, #1565C0, #1E88E5);
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.header-title {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.header-time {
  color: #999;
  font-size: 22rpx;
}

.chart-wrapper {
  width: 100%;
  height: 420rpx;
  position: relative;
}

.legend-row {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  padding: 12rpx 0 8rpx;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}

.legend-line {
  width: 22rpx;
  height: 0;
  border-top: 3rpx dashed #F44336;
  margin-right: 6rpx;
}

.legend-text {
  font-size: 20rpx;
  color: #888;
}

.metrics-row {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx 0;
  margin-top: 8rpx;
}

.metric-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.metric-label {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.metric-value {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  line-height: 1.2;
}

.metric-value.max-val {
  color: #F44336;
}

.metric-value.min-val {
  color: #4CAF50;
}

.metric-unit {
  font-size: 18rpx;
  color: #aaa;
  margin-top: 2rpx;
}

.metric-divider {
  width: 1rpx;
  height: 50rpx;
  background: #e0e0e0;
}

.section-divider {
  height: 1rpx;
  background: #eee;
  margin: 20rpx 0;
}

.selected-data-section {
  margin-top: 8rpx;
}

.section-sub-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.sub-title-icon {
  width: 6rpx;
  height: 28rpx;
  background: #1976D2;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.section-sub-title text {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
}

.grid-2x2 {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.grid-cell {
  width: 48%;
  background: #f7f8fa;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.grid-label {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.grid-value {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.grid-value.time-val { color: #1976D2; font-size: 24rpx; }
.grid-value.rz-val { color: #2196F3; }
.grid-value.inq-val { color: #4CAF50; }
.grid-value.otq-val { color: #FF9800; }

.tap-hint {
  text-align: center;
  padding: 20rpx 0 4rpx;
}

.tap-hint-text {
  font-size: 22rpx;
  color: #ccc;
}

.table-wrapper {
  width: 100%;
  overflow: hidden;
}

.table-header-row {
  display: flex;
  align-items: center;
  background: #f0f2f5;
  padding: 14rpx 8rpx;
  border-radius: 8rpx;
}

.th {
  font-size: 20rpx;
  color: #666;
  font-weight: bold;
  text-align: center;
}

.th-time {
  width: 36%;
  text-align: left;
  padding-left: 4rpx;
  flex-shrink: 0;
}

.th-data {
  flex: 1;
  min-width: 0;
}

.table-scroll {
  max-height: 600rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 14rpx 8rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.row-even {
  background: #fafbfc;
}

.td {
  font-size: 22rpx;
  color: #555;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.td-time {
  width: 36%;
  text-align: left;
  padding-left: 4rpx;
  font-size: 20rpx;
  color: #888;
  flex-shrink: 0;
}

.td-data {
  flex: 1;
  min-width: 0;
}

.disclaimer-card {
  background: #fff;
  margin: 0 20rpx 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #fde8d0;
}

.disclaimer-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.tag {
  font-size: 18rpx;
  background: #fff7e6;
  color: #fa8c16;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  border: 1rpx solid #ffd591;
  margin-right: 12rpx;
  font-weight: bold;
}

.disclaimer-title {
  font-size: 22rpx;
  color: #666;
  font-weight: bold;
}

.disclaimer-content {
  display: block;
  font-size: 20rpx;
  color: #999;
  line-height: 1.6;
  text-align: justify;
}

.bottom-spacer {
  height: 60rpx;
}